# Cấu hình API Key của Mô hình Ngôn ngữ lớn (LLM)
# Khuyên dùng 9router để auto-fallback giữa nhiều provider (Gemini, Ollama, CF Worker...)
# Nếu chưa có 9router, dùng trực tiếp OpenRouter hoặc OpenAI API.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=your_9router_api_key_here
AI_MODEL=your_model_name_here
LLM_API_BASE=https://your-9router-domain.com/v1

# Cấu hình Database (Phase 2)
# Mặc định: SQLite tại data/db.sqlite3 (không cần set gì)
# Để dùng PostgreSQL (Supabase): uncomment và điền connection string
# Dùng session-mode pooler (port 5432) để hỗ trợ cả migrations
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cấu hình Proxy cố định cho tài khoản LinkedIn của bạn (Residential Proxy tĩnh)
# Để trống nếu không sử dụng proxy trong môi trường phát triển cục bộ
PROXY_SERVER=http://your_proxy_ip:port
PROXY_USERNAME=your_proxy_user
PROXY_PASSWORD=your_proxy_pass

# Cấu hình trình duyệt
BROWSER_HEADLESS=false # Mặc định false để chạy noVNC debug nhập OTP lần đầu
BROWSER_SLOW_MO=50

# Cấu hình bảo mật Django (Khi deploy VPS)
# DJANGO_SECRET_KEY=khoa_bi_mat_ngau_nhien_va_dai_cua_ban
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your_vps_ip,localhost,127.0.0.1

# Cấu hình thông báo Telegram (Phase 1)
# Note: Dùng @chubquabot để tiện rotate API khi deploy production
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
